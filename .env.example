# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Cloud Storage Configuration
GCS_BUCKET_NAME=your-cctv-bucket
GCS_VIDEO_PREFIX=cctv-feeds/
GCS_CLIPS_PREFIX=alert-clips/

# Vertex AI Configuration
VERTEX_AI_MODEL=gemini-1.5-pro-vision
VERTEX_AI_LOCATION=us-central1

# Firebase Configuration (for Mobile Alerts)
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project

# Alert Configuration
ALERT_WEBHOOK_URL=https://your-webhook-url.com/alerts
ALERT_EMAIL_ENABLED=false
ALERT_SMS_ENABLED=false

# Video Processing Configuration
VIDEO_FRAME_RATE=1
VIDEO_ANALYSIS_INTERVAL_SECONDS=30
VIDEO_CLIP_DURATION_SECONDS=60
MAX_CONCURRENT_STREAMS=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=your-secret-key-here

# Logging
LOG_LEVEL=INFO
ENABLE_CLOUD_LOGGING=true
