# ===========================================
# Video Intelligence Agent - Configuration
# ===========================================

# REQUIRED: Google AI Studio API Key (FREE)
GEMINI_API_KEY=AIzaSyB5VivE_VYbd5A7wIVt-6aaU5BBXRbkiYg

# Local Storage (videos saved locally - no cloud needed)
LOCAL_STORAGE_PATH=./video_storage
LOCAL_CLIPS_PATH=./video_clips

# Video Processing
VIDEO_FRAME_RATE=1
VIDEO_ANALYSIS_INTERVAL_SECONDS=30
VIDEO_CLIP_DURATION_SECONDS=60

# API Server
API_HOST=0.0.0.0
API_PORT=8080

# Logging
LOG_LEVEL=INFO

# ===========================================
# OPTIONAL: Alert Webhooks (Slack, Discord, etc.)
# ===========================================
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ===========================================
# OPTIONAL: Google Cloud (for cloud storage)
# ===========================================
# GOOGLE_CLOUD_PROJECT=your-project-id
# GCS_BUCKET_NAME=your-bucket-name

# ===========================================
# OPTIONAL: Firebase (for mobile push notifications)
# ===========================================
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-key.json
# FIREBASE_PROJECT_ID=your-firebase-project
